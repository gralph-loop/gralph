#!/usr/bin/env bash
# GALP V1 launcher (subprocess reference).
#
# An editable copy of gralph's built-in default behavior: run the agent as a
# subprocess, substitute {{prompt}}, and map the exit code to a GALP outcome.
# Customize freely -- gralph treats this exactly like any other launcher.
#
# Contract (see docs/galp-v1.md):
#   argv:  <this script> -- <agent argv...>
#   env:   GALP_RESULT_FILE GALP_PROMPT_FILE GALP_TIMEOUT_MS GALP_SESSION_ID
#          GRALPH_PROFILE GRALPH_INSTANCE_NAME (passed through to the agent)
#   write: a result JSON to $GALP_RESULT_FILE; exit 0 if the launcher itself ran.
set -u

# Agent argv is everything after the first `--`.
agent=(); seen=0
for a in "$@"; do
  if [ "$seen" = 1 ]; then agent+=("$a"); continue; fi
  [ "$a" = "--" ] && seen=1
done
if [ "${#agent[@]}" -eq 0 ]; then
  echo "launcher: no agent command after --" >&2
  exit 1
fi

prompt=""
if [ -n "${GALP_PROMPT_FILE:-}" ] && [ -f "$GALP_PROMPT_FILE" ]; then
  prompt="$(cat "$GALP_PROMPT_FILE")"
fi

# Substitute {{prompt}} in every token.
cmd=()
for a in "${agent[@]}"; do cmd+=("${a//\{\{prompt\}\}/$prompt}"); done

write_result() { # $1 outcome, $2 message
  msg="$(printf '%s' "${2:-}" | sed 's/\\/\\\\/g; s/"/\\"/g')"
  printf '{"protocol":1,"outcome":"%s","message":"%s"}\n' "$1" "$msg" > "$GALP_RESULT_FILE"
}

# Optional advisory timeout.
runner=()
if [ -n "${GALP_TIMEOUT_MS:-}" ] && [ "${GALP_TIMEOUT_MS}" -gt 0 ] 2>/dev/null && command -v timeout >/dev/null 2>&1; then
  secs=$(( GALP_TIMEOUT_MS / 1000 )); [ "$secs" -lt 1 ] && secs=1
  runner=(timeout -k 5 "$secs")
fi

"${runner[@]}" "${cmd[@]}"
code=$?

if [ "$code" -eq 0 ]; then
  write_result completed ""
elif [ "$code" -eq 124 ] && [ "${#runner[@]}" -gt 0 ]; then
  write_result timed_out "agent timed out"
elif [ "$code" -eq 127 ]; then
  write_result unstartable "agent command not found"
else
  write_result crashed "agent exited with code $code"
fi
exit 0
